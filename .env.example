# Org LLM proxy
ANTHROPIC_BASE_URL=https://ai.geekyants.com
ANTHROPIC_AUTH_TOKEN=your_auth_token_here
ANTHROPIC_DEFAULT_SONNET_MODEL=geekyants/premium

